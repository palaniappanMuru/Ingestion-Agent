# ---------------------------------------------------------------------------
# CV Ingestion Agent configuration. Copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# --- Where the CVs live -----------------------------------------------------
# Absolute or relative to the project root. Supported: .pdf .docx .txt .md
CV_FOLDER=./data/cvs

# --- Claude (extraction) ----------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXTRACTION_MODEL=claude-opus-4-8
EXTRACTION_MAX_TOKENS=8000

# --- Voyage AI (embeddings) -------------------------------------------------
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024

# --- Neo4j ------------------------------------------------------------------
# Local: neo4j://localhost:7687  |  Aura: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j
